# Atlassian (Jira) Cloud
JIRA_BASE_URL=https://alamisharia.atlassian.net
JIRA_EMAIL=your-email@alamisharia.co.id
JIRA_API_TOKEN=

# Plane (self-hosted)
PLANE_BASE_URL=https://plane.hijra.internal
PLANE_API_KEY=
PLANE_WORKSPACE_SLUG=hijra-bank

# Attachments only: the assets/v2 upload endpoint is gated to logged-in users
# (session cookies) and Cloudflare Bot Management challenges scripted clients
# by TLS fingerprint. The attachments migrator shells out to system `curl`
# (which the CF policy accepts) and needs the browser's cookie header.
#
# How to obtain: open Plane in Chrome → DevTools → Network → trigger an upload
# → copy the request's `cookie:` header verbatim. Expires roughly every 24h.
# Leave blank to skip real uploads and use placeholder comments instead.
PLANE_COOKIE_HEADER=
PLANE_CSRF_TOKEN=

# Confluence PDF export (scripts/confluence-export-pdf.ts).
# Page enumeration uses JIRA_API_TOKEN above. The native "Export to PDF"
# (flyingpdf) endpoint is session-gated — token auth gets 403 — so it needs a
# logged-in browser cookie, same as PLANE_COOKIE_HEADER.
# How to obtain: open any Confluence page in Chrome → DevTools → Network →
# reload → copy the request's `cookie:` header verbatim. Expires within hours.
# CONFLUENCE_BASE_URL defaults to <JIRA_BASE_URL>/wiki; override only if needed.
CONFLUENCE_BASE_URL=
CONFLUENCE_COOKIE_HEADER=

# Google Drive upload (scripts/confluence-pdf-to-drive.ts).
# Create a "Desktop app" OAuth client in Google Cloud Console → put its id/secret
# here, then run `bun run scripts/google-auth.ts` once to fill the refresh token.
# Default scope is drive.file (app sees only files it creates) — re-auth with
# `--scope drive` if uploads into a pre-existing folder fail.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=
# Destination folder id (from the folder's Drive URL). The Confluence tree is
# mirrored as nested subfolders under this folder.
GOOGLE_DRIVE_FOLDER_ID=
# Optional: set ONLY if the destination lives on a Shared Drive (the Shared Drive id).
GOOGLE_DRIVE_ID=

# Migration runtime
LOG_LEVEL=info
DRY_RUN=false

# Sync
SYNC_OVERLAP_MINUTES=5
JIRA_TIMEZONE=Asia/Jakarta
# Optional: webhook for run summaries (Google Chat or Slack incoming webhook). Leave empty to skip.
NOTIFY_WEBHOOK_URL=
