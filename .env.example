# Atlassian (Jira) Cloud
JIRA_BASE_URL=https://alamisharia.atlassian.net
JIRA_EMAIL=your-email@alamisharia.co.id
JIRA_API_TOKEN=

# Plane (self-hosted)
PLANE_BASE_URL=https://plane.hijra.internal
PLANE_API_KEY=
PLANE_WORKSPACE_SLUG=hijra-bank

# Attachments only: the assets/v2 upload endpoint is gated to logged-in users
# (session cookies) and Cloudflare Bot Management challenges scripted clients
# by TLS fingerprint. The attachments migrator shells out to system `curl`
# (which the CF policy accepts) and needs the browser's cookie header.
#
# How to obtain: open Plane in Chrome → DevTools → Network → trigger an upload
# → copy the request's `cookie:` header verbatim. Expires roughly every 24h.
# Leave blank to skip real uploads and use placeholder comments instead.
PLANE_COOKIE_HEADER=
PLANE_CSRF_TOKEN=

# Migration runtime
LOG_LEVEL=info
DRY_RUN=false
